# Copy to .env and adjust if you deploy anywhere other than localhost.
# NEXT_PUBLIC_API_URL is baked into the frontend at build time -- it's the
# address a user's BROWSER will call, not an internal Docker network address.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated list of origins the API will accept browser requests from.
# Include the standalone frontend's origin AND the storefront(s) the chat
# widget (api/static/decorurs-widget.js) is embedded on, e.g.:
#   CORS_ORIGINS=http://localhost:3000,https://decorurs.com,https://www.decorurs.com
CORS_ORIGINS=http://localhost:3000
CORS_ORIGINS=https://decorurs.com,https://www.decorurs.com
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=decorurs-catalog