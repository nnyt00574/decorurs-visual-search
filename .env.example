# Copy to .env and adjust if you deploy anywhere other than localhost.
# NEXT_PUBLIC_API_URL is baked into the frontend at build time -- it's the
# address a user's BROWSER will call, not an internal Docker network address.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated list of origins the API will accept browser requests from.
CORS_ORIGINS=http://localhost:3000
